<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PracticumAndroidDiploma" parent="Theme.Material3.DayNight.NoActionBar">

        <item name="colorPrimary">@color/white</item>
        <item name="colorOnPrimary">@color/black</item>

        <item name="android:colorBackground">@color/white</item>
        <item name="colorOnBackground">@color/black</item>

        <item name="colorSurface">@color/gray</item>
        <item name="colorOnSurface">@color/black</item>

        <item name="colorSurfaceVariant">@color/light_gray</item>
        <item name="colorOnSurfaceVariant">@color/black</item>

        <item name="android:statusBarColor">@color/white</item>
        <item name="android:navigationBarColor">@color/bottom_navigation_menu_background</item>

        <item name="android:windowLightStatusBar">true</item>
